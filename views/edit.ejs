<%- include("partials/header", { title: "Edit Book", css: ["/public/styles/add-edit.css"] }) %>
<h1>Edit Book</h1>
<form action="/books/<%= book.id %>/edit" method="post">
	<label>ISBN<br>
		<input type="text" name="isbn" value="<%= book.isbn %>" required>
	</label>
	<br>
	<label>Title<br>
		<input type="text" name="title" value="<%= book.title %>" required>
	</label>
	<br>
	<label>Author<br>
		<input type="text" name="author" value="<%= book.author %>" required>
	</label>
	<br>
	<label>Read date<br>
		<input type="date" name="readDate" value="<%= book.read_date.toISOString().slice(0, 10) %>">
	</label>
	<br>
	<label>Rating<br>
    <div class="rating-input">
			<% for (let i = 1; i < 6; i++) { %>
				<span onclick="updateRating(<%= i %>)" class="star <%= i <= book.rating ? "filled" : "" %>">★</span>
			<% } %>
    </div>
		<textarea id="output" name="rating" style="display: none;"></textarea>
	</label>
	<br>
	<label>Notes<br>
		<textarea name="notes" rows="6"><%= book.notes %></textarea>
	</label>
	<br>
	<br>
	<button type="submit">Save</button>
</form>

<script src="/public/scripts/add-edit.js" charset="UTF-8"></script>
<%- include("partials/footer") %>
